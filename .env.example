# ============================================
# Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke GitHub!
# ============================================

# Sepolia RPC URL (dapatkan dari Alchemy / Infura)
# Contoh Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Contoh Infura: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC_URL=

# Private key akun deployer (TANPA prefix 0x)
# PERINGATAN: Gunakan akun testing, JANGAN akun mainnet!
DEPLOYER_PRIVATE_KEY=
